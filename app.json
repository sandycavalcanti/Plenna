{
  "expo": {
    "name": "Plenna",
    "slug": "Plenna",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/img/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/img/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F7FB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.Plenna"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/img/adaptive-icon.png"
      },
      "package": "com.Plenna",
      "icon": "./assets/img/icon.png",
      "iconBackgroundColor": "#E6F4FE"
    },
    "androidStatusBar": {
      "barStyle": "dark-content",
      "backgroundColor": "#E6F4FE"
    },
    "web": {
      "favicon": "./assets/img/icon.png"
    },
    "plugins": ["expo-font"],
    "extra": {
      "eas": {
        "projectId": "a4c9bb3f-30b5-42ad-82b2-2919c555f0f0"
      }
    },
    "owner": "sandycavalcanti"
  }
}
